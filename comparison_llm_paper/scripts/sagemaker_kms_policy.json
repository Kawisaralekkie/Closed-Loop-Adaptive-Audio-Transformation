{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowSageMakerUseOfBucketKmsKey",
      "Effect": "Allow",
      "Action": [
        "kms:Decrypt",
        "kms:GenerateDataKey",
        "kms:DescribeKey"
      ],
      "Resource": "arn:aws:kms:ap-southeast-1:<AWS_ACCOUNT_ID>:key/<KMS_KEY_ID>"
    }
  ]
}
